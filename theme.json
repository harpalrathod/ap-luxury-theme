{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "dusty-rose", "name": "AP Dusty Rose", "color": "#6f4e57" },
        { "slug": "champagne", "name": "AP Champagne", "color": "#c8a96a" },
        { "slug": "ivory", "name": "AP Ivory", "color": "#fff9f6" },
        { "slug": "soft-nude", "name": "AP Soft Nude", "color": "#f3e6e2" },
        { "slug": "charcoal", "name": "AP Charcoal", "color": "#2a2526" }
      ]
    },
    "typography": {
      "fontFamilies": [
        { "slug": "playfair", "name": "Playfair Display", "fontFamily": "Playfair Display, Georgia, serif" },
        { "slug": "inter", "name": "Inter", "fontFamily": "Inter, Arial, sans-serif" }
      ],
      "fluid": true
    },
    "layout": {
      "contentSize": "820px",
      "wideSize": "1280px"
    }
  },
  "styles": {
    "color": {
      "background": "#fff9f6",
      "text": "#2a2526"
    },
    "typography": {
      "fontFamily": "Inter, Arial, sans-serif"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "Playfair Display, Georgia, serif"
        }
      },
      "link": {
        "color": {
          "text": "#6f4e57"
        }
      }
    }
  }
}
